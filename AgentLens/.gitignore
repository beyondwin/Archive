# Package-local ignores for AgentLens.
# Root-level concerns (node_modules/, dist/, build/, .agentlens/, .superpowers/,
# .env*, __pycache__/, *.egg-info/) are covered by /.gitignore.

# Frontend build outputs (regenerated by `npm --prefix web run build`)
src/agentlens/web_assets/*
!src/agentlens/web_assets/__init__.py

# Vite + TypeScript caches
web/.vite/
web/*.tsbuildinfo

# Test artifacts
web/coverage/
web/playwright-report/
web/test-results/
web/tests/e2e/test-results/
