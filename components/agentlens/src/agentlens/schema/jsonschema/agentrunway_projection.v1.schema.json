{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlens.dev/schemas/agentlens.agentrunway_projection.v1.json",
  "$comment": "Derived AgentRunway projection artifact.",
  "title": "agentlens.agentrunway_projection.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "run_id", "agentrunway_run_id", "status", "event_count", "timeline", "tasks", "artifacts", "coverage", "projection_issues", "agentlens_emit_health", "payload_safety"],
  "properties": {
    "schema": {"type": "string", "const": "agentlens.agentrunway_projection.v1"},
    "run_id": {"type": "string"},
    "agentrunway_run_id": {"type": ["string", "null"]},
    "status": {"type": "string"},
    "event_count": {"type": "integer", "minimum": 0},
    "timeline": {"type": "array", "items": {"type": "object"}},
    "tasks": {"type": "object"},
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "artifact_graph", "coverage"],
      "properties": {
        "contract": {"type": "string", "enum": ["present", "missing"]},
        "artifact_graph": {"type": "string", "enum": ["present", "missing"]},
        "coverage": {"type": "string", "enum": ["present", "missing"]}
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["covered", "partial", "blocked", "unreferenced"],
      "properties": {
        "covered": {"type": "array", "items": {"type": "string"}},
        "partial": {"type": "array", "items": {"type": "string"}},
        "blocked": {"type": "array", "items": {"type": "string"}},
        "unreferenced": {"type": "array", "items": {"type": "string"}}
      }
    },
    "projection_issues": {"type": "array", "items": {"type": "object"}},
    "agentlens_emit_health": {"type": "object"},
    "payload_safety": {"type": "string", "enum": ["ok", "oversized"]}
  }
}
