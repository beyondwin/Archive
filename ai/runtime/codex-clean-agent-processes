#!/usr/bin/env zsh
set -euo pipefail

apply=0
include_build_daemons=0
include_foreign_mcp=0

usage() {
  cat <<'EOF'
Usage: codex-clean-agent-processes [--apply] [--build-daemons] [--foreign-mcp]

Default mode is dry-run. It only prints process groups that look like stale
Codex-launched MCP/tool servers.

Options:
  --apply          Send TERM to the matched process groups.
  --build-daemons  Also stop Gradle daemons with `gradle --stop`.
  --foreign-mcp    Also target MCP servers launched by other CLI agents.
                   This can terminate the owning CLI agent process group.

The matcher is intentionally narrow. It targets known Codex tool/MCP commands
instead of killing all node/java/chrome processes.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --apply) apply=1 ;;
    --build-daemons) include_build_daemons=1 ;;
    --foreign-mcp) include_foreign_mcp=1 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "unknown option: $1" >&2; usage >&2; exit 2 ;;
  esac
  shift
done

own_pgid="$(ps -o pgid= -p $$ | tr -d ' ')"

matches="$(
  ps -axo pid,ppid,pgid,etime,command |
    awk '
      /awk / { next }
      /codex-clean-agent-processes/ { next }
      /\/Applications\/Codex\.app\/Contents\/Resources\/node_repl$/ { print }
      /npm exec @playwright\/mcp|playwright-mcp/ { print }
      /pointpatch-cli.* mcp --package|pointpatch\.mcp\.McpServerKt/ { print }
      /mcp-server-darwin-arm64 --app desktop/ { print }
      /SkyComputerUseClient mcp/ { print }
    '
)"

if [[ -z "$matches" ]]; then
  echo "No matching Codex tool/MCP processes found."
else
  echo "$matches"
  pgids=("${(@f)$(echo "$matches" | awk '{print $3}' | sort -nu)}")

  if [[ "$apply" -eq 0 ]]; then
    echo
    echo "Dry-run only. Re-run with --apply to terminate these process groups:"
    printf '  -%s\n' "${pgids[@]}"
  else
    for pgid in "${pgids[@]}"; do
      [[ -z "$pgid" || "$pgid" == "$own_pgid" ]] && continue
      kill -TERM "-$pgid" 2>/dev/null || true
    done
    sleep 1
    echo "Sent TERM to matched process groups."
  fi
fi

if [[ "$include_foreign_mcp" -eq 1 ]]; then
  foreign_matches="$(
    ps -axo pid,ppid,pgid,etime,command |
      awk '
        /awk / { next }
        /codex-clean-agent-processes/ { next }
        /npm exec @upstash\/context7-mcp|context7-mcp/ { print }
        /uvx --from git\+https:\/\/github\.com\/oraios\/serena|serena start-mcp-server/ { print }
      '
  )"

  if [[ -z "$foreign_matches" ]]; then
    echo
    echo "No matching foreign MCP processes found."
  else
    echo
    echo "Foreign MCP matches:"
    echo "$foreign_matches"
    foreign_pgids=("${(@f)$(echo "$foreign_matches" | awk '{print $3}' | sort -nu)}")

    if [[ "$apply" -eq 0 ]]; then
      echo
      echo "Dry-run only. Re-run with --apply --foreign-mcp to terminate these process groups:"
      printf '  -%s\n' "${foreign_pgids[@]}"
    else
      for pgid in "${foreign_pgids[@]}"; do
        [[ -z "$pgid" || "$pgid" == "$own_pgid" ]] && continue
        kill -TERM "-$pgid" 2>/dev/null || true
      done
      sleep 1
      echo "Sent TERM to matched foreign MCP process groups."
    fi
  fi
fi

if [[ "$include_build_daemons" -eq 1 ]]; then
  if command -v gradle >/dev/null 2>&1; then
    if [[ "$apply" -eq 1 ]]; then
      gradle --stop || true
    else
      echo
      echo "Build daemon cleanup requested. Re-run with --apply --build-daemons to run: gradle --stop"
    fi
  else
    echo
    echo "gradle not found on PATH; skipping build daemon cleanup."
  fi
fi
