#!/usr/bin/env bash
# SubagentStop hook — Implementer output sanity check.
#
# Materialized into <worktree_path>/.orchestrator/hooks/check-implementer-output.sh
# at Phase 0 Step 2.5. Wired in <worktree_path>/.claude/settings.json under
# hooks.SubagentStop.
#
# Inputs (provided by Claude Code):
#   CLAUDE_TOOL_RESULT  — final assistant message from the sub-agent (text)
#
# Behavior:
#   - Only applies to Implementer dispatches. We detect this by presence of
#     a STATUS line in the sub-agent output (Reviewer/Verifier/Docs use other
#     channels via headless result files).
#   - Verifies the output contains the required fields:
#       STATUS:                (DONE or ESCALATE)
#       SUMMARY:
#       FILES_CHANGED:
#       FILES_TEST_CHANGED:
#       TDD_EVIDENCE:          (only required when STATUS is DONE)
#         - RED:               (sub-line)
#         - GREEN:             (sub-line)
#       COMMIT:                (only required when STATUS is DONE)
#   - Cross-validates TDD_EVIDENCE against FILES_TEST_CHANGED:
#       - If FILES_TEST_CHANGED lists actual test files, RED+GREEN MUST NOT both
#         be "not applicable".
#       - If RED and GREEN are both "not applicable", SUMMARY MUST mention one of
#         docs / config / generated to justify the skip.
#   - On any violation → exit 2 with diagnostic. Sub-agent then auto-retries.

set -euo pipefail

RESULT="${CLAUDE_TOOL_RESULT:-}"
[ -z "$RESULT" ] && exit 0

# Skip if this clearly isn't an Implementer sub-agent (no STATUS line).
if ! printf '%s' "$RESULT" | grep -qE '^STATUS:[[:space:]]*(DONE|ESCALATE)'; then
  exit 0
fi

STATUS_LINE="$(printf '%s' "$RESULT" | grep -E '^STATUS:' | head -1 || true)"
STATUS="$(printf '%s' "$STATUS_LINE" | sed -E 's/^STATUS:[[:space:]]*//;s/[[:space:]].*$//')"

missing=()
for field in SUMMARY FILES_CHANGED FILES_TEST_CHANGED; do
  if ! printf '%s' "$RESULT" | grep -qE "^${field}:"; then
    missing+=("$field")
  fi
done

if [ "$STATUS" = "DONE" ]; then
  if ! printf '%s' "$RESULT" | grep -qE '^COMMIT:'; then
    missing+=("COMMIT")
  fi
  if ! printf '%s' "$RESULT" | grep -qE '^TDD_EVIDENCE:'; then
    missing+=("TDD_EVIDENCE")
  fi
fi

if [ "$STATUS" = "ESCALATE" ]; then
  for field in type task blocker; do
    if ! printf '%s' "$RESULT" | grep -qE "^[[:space:]]*${field}:"; then
      missing+=("ESCALATE.${field}")
    fi
  done
fi

if [ ${#missing[@]} -ne 0 ]; then
  echo "BLOCKED: Implementer output is missing required field(s): ${missing[*]}." >&2
  echo "Re-emit the full Output Format block with all fields populated." >&2
  exit 2
fi

# TDD_EVIDENCE cross-validation (DONE only). Extracts the two sub-lines
# under the TDD_EVIDENCE: header (typically indented "  - RED:" / "  - GREEN:").
if [ "$STATUS" = "DONE" ]; then
  TDD_BLOCK="$(printf '%s' "$RESULT" | awk '
    /^TDD_EVIDENCE:/ {sub(/^TDD_EVIDENCE:[[:space:]]*/, ""); capture=1; print; next}
    capture && /^[A-Z_]+:/ {capture=0}
    capture {print}
  ')"

  RED_LINE="$(printf '%s' "$TDD_BLOCK" | grep -iE '^[[:space:]]*-?[[:space:]]*RED:' | head -1 || true)"
  GREEN_LINE="$(printf '%s' "$TDD_BLOCK" | grep -iE '^[[:space:]]*-?[[:space:]]*GREEN:' | head -1 || true)"

  if [ -z "$RED_LINE" ] || [ -z "$GREEN_LINE" ]; then
    echo "BLOCKED: TDD_EVIDENCE must contain both RED: and GREEN: sub-lines." >&2
    echo "Re-emit TDD_EVIDENCE with RED and GREEN populated (or both 'not applicable' for docs/config/generated-only tasks)." >&2
    exit 2
  fi

  # Treat "not applicable" (any case, possibly with trailing punctuation/dash) as the skip marker.
  red_na=0; green_na=0
  printf '%s' "$RED_LINE"   | grep -qiE 'not[[:space:]]+applicable' && red_na=1
  printf '%s' "$GREEN_LINE" | grep -qiE 'not[[:space:]]+applicable' && green_na=1

  # Extract FILES_TEST_CHANGED block (lines between header and next ALL_CAPS_FIELD:).
  FTC_BLOCK="$(printf '%s' "$RESULT" | awk '
    /^FILES_TEST_CHANGED:/ {sub(/^FILES_TEST_CHANGED:[[:space:]]*/, ""); capture=1; print; next}
    capture && /^[A-Z_]+:/ {capture=0}
    capture {print}
  ')"
  # Has a real test file if any non-empty, non-"none" entry exists.
  ftc_has_tests=0
  if printf '%s' "$FTC_BLOCK" | grep -vE '^[[:space:]]*(-[[:space:]]*)?(none|None|NONE)?[[:space:]]*$' | grep -qE '\S'; then
    ftc_has_tests=1
  fi

  # Rule A: real test files were touched but BOTH RED/GREEN are "not applicable" → contradiction.
  if [ "$ftc_has_tests" = "1" ] && [ "$red_na" = "1" ] && [ "$green_na" = "1" ]; then
    echo "BLOCKED: FILES_TEST_CHANGED lists test files, but TDD_EVIDENCE marks both RED and GREEN as 'not applicable'." >&2
    echo "If you touched test files, report the actual RED command + failing test summary and the GREEN command + passing summary. If the test changes are unrelated to TDD, justify in SUMMARY." >&2
    exit 2
  fi

  # Rule B: both RED/GREEN are "not applicable" but SUMMARY doesn't justify the skip.
  if [ "$red_na" = "1" ] && [ "$green_na" = "1" ]; then
    SUMMARY_BLOCK="$(printf '%s' "$RESULT" | awk '
      /^SUMMARY:/ {sub(/^SUMMARY:[[:space:]]*/, ""); capture=1; print; next}
      capture && /^[A-Z_]+:/ {capture=0}
      capture {print}
    ')"
    if ! printf '%s' "$SUMMARY_BLOCK" | grep -qiE '(docs?-only|docs?[[:space:]]+only|documentation|config-only|config[[:space:]]+only|configuration|generated[[:space:]]+only|generated-only|markdown|README)'; then
      echo "BLOCKED: TDD_EVIDENCE marks RED+GREEN as 'not applicable' but SUMMARY does not justify the skip (expected mention of docs/config/generated)." >&2
      echo "Only docs-only, config-only, or generated-only tasks may skip TDD. Add a one-phrase justification to SUMMARY or report real RED/GREEN evidence." >&2
      exit 2
    fi
  fi
fi

# v2.11: METHOD_AUDIT block required on STATUS=DONE
if [ "$STATUS" = "DONE" ]; then
  # Rule M1: at least one METHOD_AUDIT: line must be present.
  if ! printf '%s' "$RESULT" | grep -qE '^METHOD_AUDIT:'; then
    cat >&2 <<'HOOKEOF'
BLOCKED: Implementer output is missing a METHOD_AUDIT block.
STATUS=DONE requires at least one METHOD_AUDIT: line.
See references/implementer-prompt.md "METHOD_AUDIT lines" section.
HOOKEOF
    exit 2
  fi

  # Rule M2: if test files were changed, a METHOD_AUDIT: tdd applied|waived line is required.
  # Reuse ftc_has_tests computed above in the TDD_EVIDENCE cross-validation block.
  if [ "$ftc_has_tests" = "1" ]; then
    if ! printf '%s' "$RESULT" | grep -qE '^METHOD_AUDIT:[[:space:]]*tdd[[:space:]]+(applied|waived)'; then
      cat >&2 <<'HOOKEOF'
BLOCKED: Test files were changed but no METHOD_AUDIT: tdd line was emitted.
Either emit METHOD_AUDIT: tdd applied red=... green=... tests=...
or METHOD_AUDIT: tdd waived reason=<docs-only-task|config-only-task|generated-only-task>.
HOOKEOF
      exit 2
    fi
  fi

  # Rule M3: if METHOD_AUDIT: tdd applied is present, all three evidence keys must be present.
  if printf '%s' "$RESULT" | grep -qE '^METHOD_AUDIT:[[:space:]]*tdd[[:space:]]+applied'; then
    AUDIT_LINE="$(printf '%s' "$RESULT" | grep -E '^METHOD_AUDIT:[[:space:]]*tdd[[:space:]]+applied' | head -1)"
    for key in red green tests; do
      if ! printf '%s' "$AUDIT_LINE" | grep -qE "${key}="; then
        printf 'BLOCKED: METHOD_AUDIT: tdd applied is missing required key %s= on line: %s\n' "$key" "$AUDIT_LINE" >&2
        exit 2
      fi
    done
  fi
fi

exit 0
