#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import sys
from pathlib import Path


def main() -> int:
    fail = os.environ.get("AGENTRUNWAY_FAKE_AGENTLENS_FAIL") or os.environ.get("AGENTLENS_FAKE_FAIL")
    if fail:
        print(fail, file=sys.stderr)
        return 7

    argv = sys.argv[1:]
    if argv[:2] == ["run-open", "--agent"] or argv[:1] == ["run-open"]:
        log_path = os.environ.get("AGENTRUNWAY_FAKE_AGENTLENS_LOG") or os.environ.get("AGENTLENS_FAKE_LOG")
        run_id = os.environ.get("AGENTRUNWAY_FAKE_AGENTLENS_RUN_ID") or os.environ.get("AGENTLENS_FAKE_RUN_ID", "agentlens-run-1")
        if log_path:
            path = Path(log_path)
            path.parent.mkdir(parents=True, exist_ok=True)
            with path.open("a", encoding="utf-8") as handle:
                handle.write(json.dumps({"command": "run-open", "argv": argv, "run_id": run_id}, sort_keys=True) + "\n")
        print(run_id)
        return 0

    if argv[:2] == ["run-close", "--run"] or argv[:1] == ["run-close"]:
        log_path = os.environ.get("AGENTRUNWAY_FAKE_AGENTLENS_LOG") or os.environ.get("AGENTLENS_FAKE_LOG")
        if log_path:
            path = Path(log_path)
            path.parent.mkdir(parents=True, exist_ok=True)
            with path.open("a", encoding="utf-8") as handle:
                handle.write(json.dumps({"command": "run-close", "argv": argv}, sort_keys=True) + "\n")
        return 0

    if len(argv) >= 7 and argv[:2] == ["event", "append"]:
        try:
            event_type = argv[argv.index("--type") + 1]
        except (ValueError, IndexError):
            print(f"unexpected argv: {argv!r}", file=sys.stderr)
            return 2
    elif len(argv) >= 3 and argv[0] == "emit" and argv[1] == "--event-type":
        event_type = argv[2]
    else:
        if os.environ.get("AGENTRUNWAY_FAKE_AGENTLENS_STRICT") == "1":
            print(f"unexpected argv: {argv!r}", file=sys.stderr)
            return 2
        log_path = os.environ.get("AGENTRUNWAY_FAKE_AGENTLENS_LOG") or os.environ.get("AGENTLENS_FAKE_LOG")
        if log_path:
            path = Path(log_path)
            path.parent.mkdir(parents=True, exist_ok=True)
            with path.open("a", encoding="utf-8") as handle:
                handle.write(json.dumps({"command": "unsupported", "argv": argv}, sort_keys=True) + "\n")
        return 0
    raw = sys.stdin.read()
    try:
        payload = json.loads(raw)
    except json.JSONDecodeError as exc:
        print(f"invalid payload: {exc}", file=sys.stderr)
        return 3

    log_path = os.environ.get("AGENTRUNWAY_FAKE_AGENTLENS_LOG") or os.environ.get("AGENTLENS_FAKE_LOG")
    if log_path:
        path = Path(log_path)
        path.parent.mkdir(parents=True, exist_ok=True)
        with path.open("a", encoding="utf-8") as handle:
            handle.write(json.dumps({"event_type": event_type, "payload": payload}, sort_keys=True) + "\n")
    print(json.dumps({"ok": True, "event_type": event_type}, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
