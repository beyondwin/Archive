# Archive project command rules.

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Do not discard user work. Ask for explicit destructive-git approval and use a reversible alternative when possible.",
    match = [
        "git reset --hard",
        "git reset --hard HEAD~1",
    ],
    not_match = [
        "git reset --soft HEAD~1",
    ],
)

prefix_rule(
    pattern = ["git", "clean"],
    decision = "prompt",
    justification = "Cleaning untracked files can delete user work; confirm scope before running.",
    match = [
        "git clean -fd",
        "git clean -fdx",
    ],
    not_match = [
        "git status --short",
    ],
)

prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "prompt",
    justification = "Recursive deletion needs an explicit scope check.",
    match = [
        "rm -rf tmp",
        "rm -rf /tmp/example",
    ],
    not_match = [
        "rm file.txt",
    ],
)
