{
  "name": "waygent",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc -b apps/* packages/*",
    "test": "bun test ./packages/contracts/tests ./packages/runway-control/tests ./packages/lens-projectors/tests ./packages/lens-store/tests ./packages/provider-adapters/tests ./packages/policy/tests ./packages/kernel-client/tests ./packages/orchestrator/tests ./packages/context-packer/tests ./apps/cli/tests ./apps/api/tests ./apps/console/src ./tests/e2e ./tests/integration",
    "check": "bun run typecheck && bun run test",
    "platform:demo": "bun run apps/cli/src/demo.ts",
    "check:legacy": "bun run packages/testkit/src/legacyCheck.ts"
  },
  "dependencies": {
    "@waygent/orchestrator": "workspace:*",
    "@vitejs/plugin-react": "^5.1.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "vite": "^7.2.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  }
}
